{
	"name": "electrobun-svelte",
	"version": "1.0.0",
	"type": "module",
	"description": "Electrobun app with Svelte and Vite HMR",
	"scripts": {
		"start": "electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"electrobun dev\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"build:stable": "vite build && electrobun build --env=stable",
		"build:beta": "vite build && electrobun build --env=beta",
		"build:win": "vite build && electrobun build --env=stable --platform=win",
		"build:mac": "vite build && electrobun build --env=stable --platform=mac",
		"build:linux": "vite build && electrobun build --env=stable --platform=linux",
		"build:all": "vite build && electrobun build --env=stable --all-platforms",
		"check": "bun run lint && svelte-check --tsconfig ./tsconfig.json",
		"lint": "oxfmt --check && oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt ."
	},
	"dependencies": {
		"@duckdb/node-api": "^1.5.0-r.1",
		"@duckdbfan/drizzle-duckdb": "^1.3.5",
		"drizzle-orm": "^0.45.1",
		"effect": "^4.0.0-beta.33",
		"electrobun": "1.16.0",
		"waddler": "^0.1.1",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
	},
	"devDependencies": {
		"@internationalized/date": "^3.10.0",
		"@lucide/svelte": "^0.577.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/table-core": "^8.21.3",
		"@types/bun": "latest",
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"concurrently": "^9.1.0",
		"embla-carousel-svelte": "^8.6.0",
		"formsnap": "^2.0.1",
		"layerchart": "2.0.0-next.43",
		"mode-watcher": "^1.1.0",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"paneforge": "^1.0.2",
		"svelte": "^5.14.1",
		"svelte-sonner": "^1.0.7",
		"sveltekit-superforms": "^2.28.1",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.7.2",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^8.0.0"
	}
}
